{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":pinVersions"
  ],
  "semanticCommits": "enabled",
  "branchPrefix": "deps/",
  "timezone": "Europe/Berlin",
  "schedule": [
    "every weekend"
  ],
  "updateNotScheduled": false,
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "useBaseBranchConfig": "merge",
  "enabledManagers": [
    "maven",
    "npm",
    "github-actions"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": [
      "every weekend"
    ]
  },
  "packageRules": [
    {
      "groupName": "Maven build plugins",
      "matchManagers": [
        "maven"
      ],
      "matchPackageNames": [
        "/^org\\.apache\\.maven\\.plugins:/",
        "org.codehaus.mojo:build-helper-maven-plugin"
      ],
      "semanticCommitType": "build",
      "automerge": true,
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ]
    },
    {
      "groupName": "Java library dependencies",
      "matchManagers": [
        "maven"
      ],
      "matchPackageNames": [
        "com.fasterxml.jackson.core:jackson-annotations",
        "javax.annotation:javax.annotation-api"
      ],
      "semanticCommitType": "chore",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ]
    },
    {
      "groupName": "ORD specification",
      "matchManagers": [
        "npm"
      ],
      "matchFileNames": [
        "tools/annotation-gen/**"
      ],
      "matchPackageNames": [
        "@open-resource-discovery/specification"
      ],
      "semanticCommitType": "chore",
      "automerge": true,
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ]
    },
    {
      "groupName": "TypeScript generator tooling",
      "matchManagers": [
        "npm"
      ],
      "matchFileNames": [
        "tools/annotation-gen/**"
      ],
      "matchPackageNames": [
        "typescript",
        "ts-node"
      ],
      "semanticCommitType": "build",
      "automerge": true,
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ]
    },
    {
      "groupName": "GitHub Actions",
      "matchManagers": [
        "github-actions"
      ],
      "matchPackageNames": [
        "actions/checkout",
        "actions/setup-node"
      ],
      "semanticCommitType": "ci",
      "automerge": true,
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ]
    },
    {
      "groupName": "GitHub Actions",
      "matchManagers": [
        "github-actions"
      ],
      "matchPackageNames": [
        "s4u/setup-maven-action",
        "peter-evans/create-pull-request",
        "peter-evans/enable-pull-request-automerge",
        "open-resource-discovery/github-release"
      ],
      "semanticCommitType": "ci",
      "automerge": true,
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ]
    }
  ]
}